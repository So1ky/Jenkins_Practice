pipeline {
    agent any

    // нҷҳкІҪ ліҖмҲҳ м„ м–ё (нҷҳкІҪліҖмҲҳ м—ҙкұ°)
    environment {
        JUNIT_JAR_URL = 'https://repo1.maven.org/maven2/org/junit/platform/junit-platform-console-standalone/1.7.1/junit-platform-console-standalone-1.7.1.jar'
        JUNIT_JAR_PATH = 'lib/junit.jar'
        CLASS_DIR = 'classes'
        REPORT_DIR = 'test-reports'
    }

    stages {
        // мқҙлҜём§Җ 2: к№ғн—ҲлёҢм—җм„ң мҶҢмҠӨмҪ”л“ңлҘј мһҗлҸҷмңјлЎң мІҙнҒ¬м•„мӣғ н•ҙмҳҙ
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        // н…ҢмҠӨнҠё л°Ҹ м»ҙнҢҢмқј кІ°кіј м ҖмһҘ нҸҙлҚ” мғқм„ұ
        stage('Prepare') {
            steps {
                sh '''
                    mkdir -p ${CLASS_DIR}
                    mkdir -p ${REPORT_DIR}
                    mkdir -p lib
                    echo "[+] Downloading JUnit JAR..."
                    curl -L -o ${JUNIT_JAR_PATH} ${JUNIT_JAR_URL}
                '''
            }
        }

        // мһҗл°” нҢҢмқјмқ„ .classлЎң м»ҙнҢҢмқј
        stage('Build') {
            steps {
                sh '''
                    echo "[+] Compiling source files..."
                    # мҶҢмҠӨмҪ”л“ң кІҪлЎңлҘј м°ҫм•„м„ң sources.txtм—җ лӘ©лЎқ м ҖмһҘ
                    find . -name "*.java" > sources.txt
                    
                    # javacлЎң м»ҙнҢҢмқј м§„н–ү
                    javac -encoding UTF-8 -d ${CLASS_DIR} -cp ${JUNIT_JAR_PATH} @sources.txt
                '''
            }
        }

        // лӢӨмҡҙ л°ӣмқҖ Junit.jar нҢҢмқјлЎң JUnit5 н…ҢмҠӨнҠё мӢӨн–ү -> txtлЎң м ҖмһҘ (кіјм ң мЎ°кұҙ 5 л§ҢмЎұ)
        stage('Test') {
            steps {
                sh '''
                    echo "[+] Running tests with JUnit..."
                    java -jar ${JUNIT_JAR_PATH} \
                        --class-path ${CLASS_DIR} \
                        --scan-class-path \
                        --details=tree \
                        --details-theme=ascii \
                        --reports-dir ${REPORT_DIR} \
                        --config=junit.platform.output.capture.stdout=true \
                        --config=junit.platform.reporting.open.xml.enabled=true \
                        > ${REPORT_DIR}/test-output.txt
                '''
            }
        }
    }

    // мқҙлҜём§Җ 4: л№Ңл“ң м„ұкіө/мӢӨнҢЁ мқҙнӣ„мқҳ мІҳлҰ¬
    post {
        always {
            echo "[*] Archiving test results..."
            // н…ҢмҠӨнҠё кІ°кіјк°Җ лӢҙкёҙ xml нҢҢмқјмқ„ JUnit н”Ңлҹ¬к·ёмқёмқҙ мқҪмқ„ мҲҳ мһҲкІҢ мІҳлҰ¬
            junit "${REPORT_DIR}/**/*.xml"
            // txt нҢҢмқј л“ұ лӘЁл“  кІ°кіјл¬јмқ„ Jenkins ліҙкҙҖмҶҢм—җ м ҖмһҘ
            archiveArtifacts artifacts: "${REPORT_DIR}/**/*", allowEmptyArchive: true
        }
        failure {
            echo "Build or test failed"
        }
        success {
            echo "Build and test succeeded"
            mail subject: "л№Ңл“ң м„ұкіө: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                 body: "л№Ңл“ңмҷҖ н…ҢмҠӨнҠёк°Җ м„ұкіөм ҒмңјлЎң мҷ„лЈҢлҗҳм—ҲмҠөлӢҲлӢӨ. мғҒм„ё кІ°кіјлҠ” лӢӨмқҢ URLм—җм„ң нҷ•мқён•ҳм„ёмҡ”: ${env.BUILD_URL}",
                 to: 'xofla0331@gmail.com',
                 from: 'jenkins@your-company.com',
                 replyTo: 'admin@your-company.com',
                 mimeType: 'text/plain'
        }
    }
}
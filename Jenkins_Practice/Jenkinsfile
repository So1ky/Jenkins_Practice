pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        
        stage('Build in Docker') {
            steps {
                echo '도커 컨테이너를 직접 실행하여 Java 코드를 빌드합니다...'
                // sh 명령어를 통해 도커를 직접 실행! (이건 로그에서 성공했던 방식임)
                // 현재 젠킨스 워크스페이스(코드 위치)를 도커 안의 /app 폴더로 연결해서 빌드함
                sh '''
                docker run --rm -v $(pwd):/app -w /app eclipse-temurin:17-jdk-jammy sh -c "
                    mkdir -p bin && javac -d bin src/**/*.java
                "
                '''
            }
        }
    }

    post {
        success {
            echo '빌드 성공! 결과 파일을 생성합니다.'
            sh 'echo "Build Successful using Docker! Date: $(date)" > build_success.txt'
            archiveArtifacts artifacts: 'build_success.txt', allowEmptyArchive: true
        }
        failure {
            echo '빌드 실패! 로그를 다시 확인하세요.'
        }
    }
}